    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
