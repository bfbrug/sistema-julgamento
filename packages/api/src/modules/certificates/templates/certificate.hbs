<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @page { size: A4 landscape; margin: 0; }
    * { box-sizing: border-box; }
    body { margin: 0; padding: 0; font-family: 'Times New Roman', Times, serif; }

    .certificate {
      width: 297mm;
      height: 210mm;
      page-break-after: always;
      position: relative;
      background-image: url('{{backgroundUrl}}');
      background-size: cover;
      background-position: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 20mm;
    }

    .certificate:last-child {
      page-break-after: auto;
    }

    .title {
      font-size: 28pt;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 12mm;
      color: #1a1a2e;
    }

    .name {
      font-size: 36pt;
      font-weight: bold;
      margin-bottom: 10mm;
      color: #1a1a2e;
    }

    .text {
      font-size: 16pt;
      line-height: 1.6;
      max-width: 220mm;
      margin-bottom: 14mm;
      color: #1a1a2e;
    }

    .signatures {
      display: flex;
      justify-content: center;
      gap: 20mm;
      margin-top: auto;
      margin-bottom: 8mm;
    }

    .signature {
      display: flex;
      flex-direction: column;
      align-items: center;
      min-width: 50mm;
    }

    .signature img {
      max-height: 20mm;
      max-width: 50mm;
      object-fit: contain;
      margin-bottom: 3mm;
    }

    .signature-name {
      font-size: 12pt;
      font-weight: bold;
      border-top: 1px solid #1a1a2e;
      padding-top: 2mm;
      width: 100%;
    }

    .signature-role {
      font-size: 10pt;
      color: #444;
    }

    .verification {
      position: absolute;
      bottom: 5mm;
      right: 5mm;
      font-size: 8pt;
      color: #666;
      text-align: right;
      line-height: 1.4;
    }
  </style>
</head>
<body>
  {{#each participants}}
    <div class="certificate">
      <div class="title">CERTIFICADO DE PARTICIPAÇÃO</div>
      <div class="name">{{this.name}}</div>
      <div class="text">{{{this.processedText}}}</div>

      <div class="signatures">
        {{#each ../signatures}}
          <div class="signature">
            <img src="{{this.imageUrl}}" />
            <div class="signature-name">{{this.personName}}</div>
            <div class="signature-role">{{this.personRole}}</div>
          </div>
        {{/each}}
      </div>

      <div class="verification">
        Código: {{../verificationCode}}-{{this.id}}<br>
        Gerado em: {{../generatedAt}}
      </div>
    </div>
  {{/each}}
</body>
</html>
