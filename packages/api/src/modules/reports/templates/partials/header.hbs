<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 12px; color: #222; background: #fff; }
    h1 { font-size: 20px; font-weight: bold; margin-bottom: 4px; }
    h2 { font-size: 15px; font-weight: 600; margin-bottom: 12px; color: #444; }
    .event-meta { font-size: 11px; color: #666; margin-bottom: 20px; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
    th { background: #1a1a2e; color: #fff; padding: 8px 10px; text-align: left; font-size: 11px; font-weight: 600; }
    td { padding: 7px 10px; border-bottom: 1px solid #e8e8e8; font-size: 11px; }
    tr:nth-child(even) td { background: #f7f7fb; }
    .position { font-weight: bold; text-align: center; width: 50px; }
    .score { font-weight: bold; text-align: right; width: 80px; }
    .section-title { font-size: 13px; font-weight: bold; margin: 20px 0 8px; color: #333; border-bottom: 2px solid #1a1a2e; padding-bottom: 4px; }
    .absent-list { font-size: 11px; color: #666; }
    .absent-list li { padding: 3px 0; }
    .warning-box { background: #fff8e1; border: 1px solid #ffc107; padding: 8px 12px; border-radius: 4px; margin-bottom: 16px; font-size: 11px; color: #7c5d00; }
    .tie-marker { color: #888; font-size: 10px; margin-left: 4px; }
  </style>
</head>
<body>
